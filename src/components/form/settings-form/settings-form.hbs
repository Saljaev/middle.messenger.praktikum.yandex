<div class="settings-form">
  <div class="settings-form__section settings-form__section--personal">
    <h2 class="settings-form__section-title">Личная информация</h2>

    <div class="settings-profile">
      <a href="/settings/avatar" class="settings-profile__avatar" title="Нажмите чтобы изменить аватар">
        {{> avatar url=currentUser.avatarUrl name=first_name size="large"}}
        <div class="settings-profile__avatar-overlay">
          {{> edit-icon size="small"}}
        </div>
      </a>
    </div>

    <form class="form" id="settingsForm">
      <div class="form__group">
        <label for="first_name" class="form__label">Имя</label>
        <input type="text" id="first_name" name="first_name" class="input" value="{{first_name}}" required>
      </div>

      <div class="form__group">
        <label for="second_name" class="form__label">Фамилия</label>
        <input type="text" id="second_name" name="second_name" class="input" value="{{second_name}}" required>
      </div>
    </form>
  </div>

  <div class="settings-form__section">
    <h2 class="settings-form__section-title">Данные аккаунта</h2>

    <form class="form" id="accountForm">
      <div class="form__group">
        <label for="display_name" class="form__label">Отображаемое имя</label>
        <div class="display-name-field">
          <input type="text" id="display_name" name="display_name" class="input" value="{{display_name}}" readonly>
          <button type="button" class="button button_icon" id="generateDisplayName" title="Сгенерировать новое имя">
            {{> edit-icon size="small"}}
          </button>
        </div>
      </div>

      <div class="form__group">
        <label for="login" class="form__label">Логин</label>
        <input type="text" id="login" name="login" class="input" value="{{login}}" required>
      </div>

      <div class="form__group">
        <label for="email" class="form__label">Почта</label>
        <input type="email" id="email" name="email" class="input" value="{{email}}" required>
      </div>

      <div class="form__group">
        <label for="phone" class="form__label">Телефон</label>
        <input type="tel" id="phone" name="phone" class="input" value="{{phone}}" required>
      </div>
    </form>
  </div>

  <div class="settings-form__section settings-form__section--security">
    <h2 class="settings-form__section-title">Безопасность</h2>
    <div class="settings-form__link">
      <a class="settings-link" href="/settings/password">
        Изменить пароль
        {{> back-icon size="small"}}
      </a>
    </div>
  </div>
</div>

<div class="settings-form__footer">
  <button type="button" class="settings-link settings-link--primary" id="saveSettings">
    Сохранить изменения
  </button>
  <button type="button" class="settings-link settings-link--danger" id="logoutLink">
    Выйти из аккаунта
  </button>
</div>
