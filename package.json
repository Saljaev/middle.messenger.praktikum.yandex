{
    "name": "course",
    "version": "1.0.0",
    "description": "",
    "main": "dist/index.js",
    "scripts": {
        "start": "npm run build && vite preview --port 3000",
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "type-check": "tsc --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "lint:css": "stylelint 'src/**/*.scss' 'src/**/*.css'",
        "lint:css:fix": "stylelint 'src/**/*.scss' 'src/**/*.css' --fix",
        "format": "prettier --check .",
        "format:fix": "prettier --write .",
        "check:all": "eslint src && stylelint 'src/**/*.scss' && prettier --check .",
        "check:all:fix": "eslint src --fix && stylelint 'src/**/*.scss' --fix && prettier --write .",
        "test": "vitest",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.15.17",
        "@typescript-eslint/eslint-plugin": "^8.59.3",
        "@typescript-eslint/parser": "^8.59.3",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.6.0",
        "happy-dom": "^20.10.3",
        "husky": "^9.1.7",
        "prettier": "^3.8.3",
        "sass-embedded": "^1.99.0",
        "stylelint": "^17.11.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "typescript": "^5.5.3",
        "vite": "^8.0.12",
        "vite-plugin-handlebars": "^2.0.3",
        "vitest": "^4.1.6"
    },
    "private": true,
    "type": "module",
    "dependencies": {
        "handlebars": "^4.7.9"
    }
}
